{
  "version": 2,
  "builds": [
    {
      "src": "api/working_api.py",
      "use": "@vercel/python",
      "config": {
        "pythonVersion": "3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/working_api.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}