{
  "builds": [
    {
      "src": "api/working_api.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/web/simple_sci_listen.html"
    },
    {
      "src": "/api/(.*)",
      "dest": "api/working_api.py"
    },
    {
      "src": "/(.*)",
      "dest": "/web/$1"
    }
  ]
}